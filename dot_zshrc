# Add deno completions to search path
if [[ ":$FPATH:" != *":/Users/gaoyibo/.zsh/completions:"* ]]; then export FPATH="/Users/gaoyibo/.zsh/completions:$FPATH"; fi
bindkey '\e[1;3D' backward-word       # ALT+左键：向后跳一个单词
bindkey '\e[1;3C' forward-word        # ALT+右键：前跳一个单词

# If you come from bash you might have to change your $PATH.
export PATH=$PATH:$HOME/bin:/usr/local/bin
export PATH=$PATH:/Users/gaoyibo/flutter/bin
export PATH=$PATH:/Users/gaoyibo/go/bin
export PATH=$PATH:/Users/gaoyibo
export PATH=$PATH:/Users/gaoyibo/opt/anaconda3/bin

export LC_ALL='en_US.UTF-8'
export LANG='en_US.UTF-8'

if [[ "~/opt/miniconda3" ]]; then
    export PATH=$PATH:~/opt/miniconda3/bin
fi

# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh

# Android
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/tools/bin
export PATH=$PATH:$ANDROID_HOME/platform-tools
export PATH=$PATH:$ANDROID_HOME/emulator

# Set name of the theme to load. Optionally, if you set this to "random"
# it'll load a random theme each time that oh-my-zsh is loaded.
# See https://github.com/robbyrussell/oh-my-zsh/wiki/Themes
ZSH_THEME="robbyrussell"
# ZSH_THEME="bira"

plugins=(
  dotenv
  git
  macos
  docker
  autojump
  zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# tabtab source for electron-forge package
# uninstall by removing these lines or running `tabtab uninstall electron-forge`
[[ -f /Users/gaoyibo/github/electron-react-boilerplate/node_modules/tabtab/.completions/electron-forge.zsh ]] && . /Users/gaoyibo/github/electron-react-boilerplate/node_modules/tabtab/.completions/electron-forge.zsh

# alias start
## shadow socks5 http proxy:
alias p-on='export https_proxy=http://127.0.0.1:8891 http_proxy=http://127.0.0.1:8891 all_proxy=socks5://127.0.0.1:8891'
alias p-off='unset http_proxy;unset https_proxy'

## k8s
alias k='kubectl'
# For switching context between different clusters
alias kswitch-maryam='kubectl config use-context maryam'
alias kswitch-mary='kubectl config use-context mary'
alias kpod='kubectl get pods -A'
alias knode='kubectl get nodes'
alias kdesp='kubectl describe pod'
alias kdp='kubectl delete pod'
alias kgd='kubectl get deployments'

## some app
alias sb="'/Applications/Sublime Text.app/Contents/SharedSupport/bin/subl'"
alias ls="eza"
alias ping="prettyping"
alias top="btm"
alias ps="procs"
alias cc=claude
alias cz=chezmoi
# alias end

# k8s auto complete
if [[ "type kubectl" ]]; then
    source <(kubectl completion zsh)
fi

export PATH="/usr/local/opt/ruby/bin:$PATH"
# export PATH="/usr/local/opt/python3.9/bin:$PATH"
export PATH="/opt/homebrew/Cellar/python@3.10/3.10.14/bin:$PATH"
# export PATH="/opt/homebrew/opt/python@3.11/bin:$PATH"
export PATH="/usr/local/opt/openresty-openssl111/bin:$PATH"
export PATH="/usr/local/Cellar/openresty/1.19.3.1_1/bin:$PATH"
export PATH="/usr/local/Cellar/openresty/1.19.3.1_1/nginx/sbin:$PATH"
source ~/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/miniconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/miniconda3/etc/profile.d/conda.sh" ]; then
        . "/opt/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="/opt/miniconda3/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

export PATH="/usr/local/opt/php@8.0/bin:$PATH"
export PATH="/usr/local/opt/php@8.0/sbin:$PATH"

# export RUSTUP_DIST_SERVER="https://rsproxy.cn"
# export RUSTUP_UPDATE_ROOT="https://rsproxy.cn/rustup"

export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"

export DOCKER_BUILDKIT=0

# pnpm
export PNPM_HOME="/Users/gaoyibo/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"
# pnpm end

export TA_INCLUDE_PATH="$(brew --prefix ta-lib)/include"
export TA_LIBRARY_PATH="$(brew --prefix ta-lib)/lib"

# Wasmer
export WASMER_DIR="/Users/gaoyibo/.wasmer"
[ -s "$WASMER_DIR/wasmer.sh" ] && source "$WASMER_DIR/wasmer.sh"

export WASMTIME_HOME="$HOME/.wasmtime"
