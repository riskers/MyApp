# Haskell
export PATH="~/.ghcup/hls/2.7.0.0/bin/haskell-language-server-wrapper:$PATH"
[ -f "/Users/gaoyibo/.ghcup/env" ] && source "/Users/gaoyibo/.ghcup/env" # ghcup-env

# hide hostname and username
DISABLE_AUTO_TITLE="true"

export PATH="$PATH:/Users/gaoyibo/.lmstudio/bin"

export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"

# opencode
export PATH=/Users/gaoyibo/.opencode/bin:$PATH

# fnm
eval "$(fnm env --use-on-cd --shell zsh)"

