bindkey '\e[1;3D' backward-word       # ALT+左键：向后跳一个单词
bindkey '\e[1;3C' forward-word        # ALT+右键：前跳一个单词

export WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'

# If you come from bash you might have to change your $PATH.
export PATH=$PATH:$HOME/bin:/usr/local/bin
export PATH=$PATH:$HOME/flutter/bin
export PATH=$PATH:$HOME/go/bin
export PATH=$PATH:$HOME
export PATH=$PATH:$HOME/opt/anaconda3/bin

export LC_ALL='en_US.UTF-8'
export LANG='en_US.UTF-8'

if [[ "~/opt/miniconda3" ]]; then
    export PATH=$PATH:~/opt/miniconda3/bin
fi

# starship load
eval "$(starship init zsh)"

# zplug start `https://github.com/zplug/zplug`
export ZPLUG_HOME=/usr/local/opt/zplug
source $ZPLUG_HOME/init.zsh

zplug "zsh-users/zsh-autosuggestions"
zplug "zsh-users/zsh-syntax-highlighting"
zplug "zsh-users/zsh-completions"
zplug "zsh-users/zsh-history-substring-search"
zplug "plugins/autojump", from:oh-my-zsh
zplug "plugins/brew", from:oh-my-zsh
zplug "plugins/docker", from:oh-my-zsh
zplug "plugins/docker-compose", from:oh-my-zsh
zplug "plugins/dotenv", from:oh-my-zsh
zplug "plugins/eza", from:oh-my-zsh
zplug "plugins/fnm", from:oh-my-zsh
zplug "plugins/git", from:oh-my-zsh
zplug "plugins/helm", from:oh-my-zsh
zplug "plugins/httpie", from:oh-my-zsh
zplug "plugins/macos", from:oh-my-zsh
zplug "plugins/kubectl", from:oh-my-zsh
zplug "plugins/ngrok", from:oh-my-zsh
zplug "plugins/pm2", from:oh-my-zsh
zplug "plugins/redis-cli", from:oh-my-zsh
zplug "plugins/sudo", from:oh-my-zsh
zplug "plugins/sublime", from:oh-my-zsh
zplug "plugins/ssh", from:oh-my-zsh
zplug "plugins/uv", from:oh-my-zsh

if ! zplug check --verbose; then
    printf "Install? [y/N]: "
    if read -q; then
        echo; zplug install
    fi
fi

zplug load # --verbose
# zplug end

# tabtab source for electron-forge package
# uninstall by removing these lines or running `tabtab uninstall electron-forge`
[[ -f $HOME/github/electron-react-boilerplate/node_modules/tabtab/.completions/electron-forge.zsh ]] && . $HOME/github/electron-react-boilerplate/node_modules/tabtab/.completions/electron-forge.zsh

# alias start
## socks5 proxy:
alias p-on='export https_proxy=http://127.0.0.1:8891 http_proxy=http://127.0.0.1:8891 all_proxy=socks5://127.0.0.1:8891'
alias p-off='unset http_proxy;unset https_proxy'

## k8s
alias k='kubectl'
# For switching context between different clusters
alias kswitch-maryam='kubectl config use-context maryam'
alias kswitch-mary='kubectl config use-context mary'
alias kpod='kubectl get pods -A'
alias knode='kubectl get nodes'
alias kdesp='kubectl describe pod'
alias kdp='kubectl delete pod'
alias kgd='kubectl get deployments'

## some app
alias cat="bat"
# alias ls="eza"
alias find="fd"
alias ping="prettyping"
alias top="btm"
alias cz=chezmoi
alias grep="rg"
alias ps="procs"
alias cc=claude
# alias end

# k8s auto complete
if [[ "type kubectl" ]]; then
    source <(kubectl completion zsh)
fi

export PATH="/usr/local/opt/ruby/bin:$PATH"
# export PATH="/usr/local/opt/python3.9/bin:$PATH"
export PATH="/opt/homebrew/Cellar/python@3.10/3.10.14/bin:$PATH"
