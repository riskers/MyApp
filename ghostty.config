# ============================================
# Ghostty Terminal - Complete Configuration
# ============================================
# File: ~/.config/ghostty/config
# Reload: Cmd+Shift+, (macOS)
# View options: ghostty +show-config --default --docs

# --- Typography ---
font-family = "Comic Mono"
font-feature = "calt"
font-variation = "wght=500"
font-size = 16
font-thicken = true
adjust-cell-height = 2

# --- Shell Integration ---
shell-integration = zsh

# term=xterm-256color
# clipboard-read = allow
# clipboard-write = allow

# --- Theme and Colors ---
# Catppuccin with automatic light/dark switching
theme = Catppuccin Mocha

# Colors
palette = 0=#000000
palette = 1=#ef85ee
palette = 2=#a2caa0
palette = 3=#fae0c2
palette = 4=#a1caf9
palette = 5=#c6c5f9
palette = 6=#a1caf9
palette = 7=#e6e6e6
palette = 8=#888888
palette = 9=#ef85ee
palette = 10=#b5f464
palette = 11=#f8fdbe
palette = 12=#afd4fb
palette = 13=#c6c5f9
palette = 14=#a1caf9
palette = 15=#e6e6e6
background = #1d1f21
foreground = #d0d2d1
selection-background = #565656
selection-foreground = #d0d2d1

# --- Window and Appearance ---
background-opacity = 0.9
background-blur = 10
background-blur-radius = 30
macos-titlebar-style = transparent
window-padding-x = 10
window-padding-y = 8
window-save-state = always
window-theme = auto

# macos-option-as-alt = left
# fullscreen = false

# --- Mouse ---
mouse-hide-while-typing = true
copy-on-select = clipboard

# --- Cursor ---
cursor-style=block
cursor-style-blink=false
# adjust-cell-height = 2
adjust-cursor-thickness=16

# 配置图标
# macos-icon = glass

# --- Quick Terminal (Quake-style dropdown) ---
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-autohide = true
quick-terminal-animation-duration = 0.15

# --- Security ---
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# 使用默认文本编辑器进行搜索
# 以下两条配置会把完整的窗口文本信息输出到文本编辑器
# 将当前的窗口回滚文件（不包含当前屏幕文本信息）使用默认文本编辑器打开
keybind = command+f=write_scrollback_file:open
# 将当前屏幕文本信息使用默认文本编辑器打开
keybind = command+f=write_screen_file:open

keybind = cmd+right=text:\x05
keybind = cmd+left=text:\x01
keybind = cmd+backspace=text:\x15

# --- Keybindings ---
# Tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+w=close_surface

# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# Font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Quick terminal global hotkey
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Splits management
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom

# Reload config
keybind = cmd+shift+comma=reload_config
